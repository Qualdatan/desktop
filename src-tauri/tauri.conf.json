{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qualdatan Desktop",
  "version": "0.1.0",
  "identifier": "org.qualdatan.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Qualdatan Desktop",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/qualdatan-sidecar"],
    "category": "Productivity",
    "shortDescription": "Qualdatan Desktop",
    "longDescription": "Qualitative Analyse-Pipeline (Tauri-Shell + FastAPI-Sidecar).",
    "windows": {
      "nsis": {
        "template": "installer/installer.nsi",
        "license": "../LICENSE",
        "installMode": "perMachine",
        "languages": ["English", "German"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Qualdatan/desktop/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBNDk0OTRCNjBFMzY4QUIKUldTcmFPTmdTMGxKaXFOUnpFWS94aktJZHdZQTlCbFRmb3B3WTFRMU9sUk1Nd05TVDU5MGo5K3cK"
    }
  }
}
