{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qualdatan Desktop",
  "version": "0.1.0",
  "identifier": "org.qualdatan.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Qualdatan Desktop",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/qualdatan-sidecar"],
    "category": "Productivity",
    "shortDescription": "Qualdatan Desktop",
    "longDescription": "Qualitative Analyse-Pipeline (Tauri-Shell + FastAPI-Sidecar)."
  }
}
